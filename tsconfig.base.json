{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@escronet/shared": ["./packages/shared/src/index.ts"],
      "@escronet/shared/*": ["./packages/shared/src/*"]
    }
  }
}
