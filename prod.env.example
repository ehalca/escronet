# Database password — must match POSTGRES_PASSWORD below
DB_PASSWORD=

# Postgres image reads this env var to set the superuser password.
# Set to the same value as DB_PASSWORD.
POSTGRES_PASSWORD=

# Firebase Admin SDK service account JSON (loaded from the bind-mounted file)
FIREBASE_SERVICE_ACCOUNT_JSON=/run/secrets/firebase-service-account.json

# Public backend URL baked into the Next.js bundle at build time.
# Must include protocol, no trailing slash. Example: https://api.escronet.com
NEXT_PUBLIC_BACKEND_URL=https://escronet.com
