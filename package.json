{
  "name": "escronet",
  "private": true,
  "version": "0.1.0",
  "description": "On-device scam call prevention platform (React Native + NestJS)",
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "pnpm --filter @escronet/frontend dev",
    "build:frontend": "pnpm --filter @escronet/frontend build",
    "dev:backend": "pnpm --filter @escronet/backend start:dev",
    "build:backend": "pnpm --filter @escronet/backend build",
    "start:backend": "pnpm --filter @escronet/backend start",
    "dev:mobile": "pnpm --filter @escronet/mobile start",
    "android": "pnpm --filter @escronet/mobile android",
    "emulator": "pnpm --filter @escronet/mobile emulator",
    "dev:android": "pnpm --filter @escronet/mobile dev:android",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  }
}
